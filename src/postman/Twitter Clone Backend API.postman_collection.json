        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  if(jsonData.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "  } else if(jsonData.data && jsonData.data.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.data.token);",
                  "  } else if(jsonData.accessToken) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.accessToken);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"milan@example.com\", \"password\": \"Password123\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
